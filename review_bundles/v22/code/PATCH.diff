+def _num(path: Path, key: str) -> int:
+    if not path.exists():
+        return 0
+    m = re.search(rf"{re.escape(key)}: `?(\d+)`?", path.read_text(encoding="utf-8"))
+    return int(m.group(1)) if m else 0
+
+
